# Optional: environment variables for local development.
# ASP.NET Core reads these automatically (use double underscore for nested keys).
#
# Prefer appsettings.Development.json for ConnectionStrings — see
# appsettings.Development.json.example in this folder.
#
# Examples (PowerShell):
#   $env:ASPNETCORE_ENVIRONMENT = "Development"
#   $env:ConnectionStrings__DefaultConnection = "Server=localhost;Database=ProSportDb;Trusted_Connection=True;TrustServerCertificate=True"
#
# Examples (bash):
#   export ASPNETCORE_ENVIRONMENT=Development
#   export ConnectionStrings__DefaultConnection="Server=localhost;Database=ProSportDb;Trusted_Connection=True;TrustServerCertificate=True"

ASPNETCORE_ENVIRONMENT=Development

# SQL Server connection (used when EF Core is configured in later sprints)
ConnectionStrings__DefaultConnection=Server=localhost;Database=ProSportDb;Trusted_Connection=True;TrustServerCertificate=True
